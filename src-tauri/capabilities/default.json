{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Parsec",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/parsec-sidecar",
          "sidecar": true
        }
      ]
    },
    "shell:allow-stdin-write"
  ]
}
