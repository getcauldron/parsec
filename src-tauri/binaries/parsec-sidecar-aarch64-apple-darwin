#!/usr/bin/env bash
# Sidecar launcher: spawns the PyInstaller-built parsec-sidecar binary.
#
# In dev mode (cargo tauri dev), Tauri copies this script to target/debug/
# and executes it. We resolve back to the PyInstaller --onedir output.
#
# In production, this wrapper is replaced by the actual binary during
# the Tauri bundle step.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$SCRIPT_DIR"

# Walk up to find the project root (where backend/ lives).
for _ in 1 2 3 4 5; do
  if [ -d "$PROJECT_ROOT/backend" ]; then
    break
  fi
  PROJECT_ROOT="$(dirname "$PROJECT_ROOT")"
done

BINARY="$PROJECT_ROOT/backend/dist/parsec-sidecar/parsec-sidecar"

if [ ! -x "$BINARY" ]; then
  # Fallback to dev-mode venv Python if PyInstaller binary not built yet.
  VENV_PYTHON="$PROJECT_ROOT/backend/.venv/bin/python"
  SIDECAR="$PROJECT_ROOT/backend/parsec/sidecar.py"
  if [ -x "$VENV_PYTHON" ] && [ -f "$SIDECAR" ]; then
    exec "$VENV_PYTHON" -u "$SIDECAR"
  fi
  echo "ERROR: parsec-sidecar binary not found at $BINARY" >&2
  echo "Run ./backend/build_sidecar.sh to build it." >&2
  exit 1
fi

exec "$BINARY"
