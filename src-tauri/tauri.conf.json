{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parsec",
  "version": "0.1.0",
  "identifier": "com.getcauldron.parsec",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Parsec",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost https://github.com https://objects.githubusercontent.com"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0NDMzOTkxMDQyOUE1NkYKUldSdnBTa0VrVGxETkJiN21ha0RFZm1PdUliOGRMWS91Zi9KY1VQdEFTc2c3YWwvbEZUcGxPOXkK",
      "endpoints": [
        "https://github.com/getcauldron/parsec/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": ["binaries/parsec-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../backend/dist/parsec-sidecar/_internal/**/*": "_internal/"
    },
    "macOS": {
      "files": {
        "Frameworks": "../backend/dist/parsec-sidecar/_internal"
      }
    }
  }
}
